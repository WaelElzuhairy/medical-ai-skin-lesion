# Copy to .env and fill in. Never commit .env.
# Anthropic API key — required for Phase 2 (agentic layer). Phase 1 (CNN + Grad-CAM) runs without it.
ANTHROPIC_API_KEY=

# Optional: override the default Anthropic model used by every agent.
# Default (set in config.py) is claude-haiku-4-5 — cheap, fast, reliable structured output.
ANTHROPIC_MODEL=

# Optional: NCBI E-utilities API key. Not required, but raises rate limit from 3/s to 10/s
# during PubMed corpus ingestion. Get one free at https://www.ncbi.nlm.nih.gov/account/.
NCBI_API_KEY=
